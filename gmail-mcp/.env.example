# Gmail MCP — Sensitive paths (DO NOT commit this file)
# Copy this file to .env and fill in your actual paths

# Absolute path to venv Python
GMAIL_VENV_PYTHON=/path/to/gmail-mcp/venv/bin/python3

# Absolute path to this MCP server script
GMAIL_SERVER_PATH=/path/to/gmail-mcp/gmail_mcp_server.py

# Path to Google OAuth credentials JSON (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=/path/to/gmail-mcp/credentials.json

# Path to token file (auto-generated after first OAuth login)
GMAIL_TOKEN_FILE=/path/to/gmail-mcp/token.json
